# serializer version: 1
# name: TestDOC001.test_rule
  '''
  ━━━ Diagnostics ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  DOC001 [unsafe] Docstring sections are not in canonical order.
    --> doc001.py:8:5
     |
   6 |     """Do something.
   7 | 
   8 |     Returns:
     |     ^^^^^^^^
   9 |         int: The result.
     | ^^^^^^^^^^^^^^^^^^^^^^^^
  10 | 
  11 |     Args:
     |
  
  ━━━ Diff ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  --- doc001.py
  +++ doc001.py (fixed)
  @@ -5,11 +5,11 @@
   def wrong_order(x: int) -> int:
       """Do something.
   
  +    Args:
  +        x (int): The input.
  +
       Returns:
           int: The result.
  -
  -    Args:
  -        x (int): The input.
       """
       return x
  '''
# ---
