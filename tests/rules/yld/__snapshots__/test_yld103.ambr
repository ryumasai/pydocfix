  YLD103 [unsafe] Yield has no type in docstring.
    --> yld103.py:12:9
     |
  10 | 
  11 |     Yields:
  12 |         The value with no type in docstring.
     |         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  13 |     """
  14 |     yield 42
     |
  
  ━━━ Diff ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  --- yld103.py
  +++ yld103.py (fixed)
  @@ -9,7 +9,7 @@
