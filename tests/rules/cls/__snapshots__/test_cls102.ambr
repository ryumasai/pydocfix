  cls102.py:8:5: CLS102 [safe] Class docstring should not have a Yields section.
     |
   7 | 
   8 |     Yields:
     |     ^^^^^^^
   9 |         int: Some value.
     | ^^^^^^^^^^^^^^^^^^^^^^^^
  10 |     """
     |
  
  ━━━ Diff ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  --- cls102.py
  +++ cls102.py (fixed)
  @@ -4,9 +4,6 @@
   # violation: class docstring contains Yields section
   class HasYieldsSection:
       """A class.
  -
  -    Yields:
  -        int: Some value.
       """
   
       pass
  '''
