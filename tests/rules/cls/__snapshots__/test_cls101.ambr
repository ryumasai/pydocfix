  cls101.py:8:5: CLS101 [safe] Class docstring should not have a Returns section.
     |
   7 | 
   8 |     Returns:
     |     ^^^^^^^^
   9 |         int: Some value.
     | ^^^^^^^^^^^^^^^^^^^^^^^^
  10 |     """
     |
  
  ━━━ Diff ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  --- cls101.py
  +++ cls101.py (fixed)
  @@ -4,9 +4,6 @@
   # violation: class docstring contains Returns section
   class HasReturnsSection:
       """A class.
  -
  -    Returns:
  -        int: Some value.
       """
   
       pass
  '''
