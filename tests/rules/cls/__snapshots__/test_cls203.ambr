  cls203.py:10:9: CLS203 [unsafe] __init__ docstring should not have an Args/Parameters section when class_docstring_style is 'class'.
     |
   9 | 
  10 |         Args:
     |         ^^^^^
  11 |             x: The value.
     | ^^^^^^^^^^^^^^^^^^^^^^^^^
  12 |         """
     |
  
  ━━━ Diff ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  --- cls203.py
  +++ cls203.py (fixed)
  @@ -6,9 +6,6 @@
   class InitHasArgsClass:
       def __init__(self, x: int) -> None:
           """Initialize.
  -
  -        Args:
  -            x: The value.
           """
           self.x = x
  '''
