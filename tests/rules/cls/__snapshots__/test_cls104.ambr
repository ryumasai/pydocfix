# serializer version: 1
# name: TestCLS104.test_rule
  '''
  ━━━ Diagnostics ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  cls104.py:9:5: CLS104 [unsafe] Class docstring should not have a Raises section when class_docstring_style is 'init'.
     |
   8 | 
   9 |     Raises:
     |     ^^^^^^^
  10 |         ValueError: If x is negative.
     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  11 |     """
     |
  
  ━━━ Diff ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  --- cls104.py
  +++ cls104.py (fixed)
  @@ -5,9 +5,6 @@
   # violation: class docstring has Raises section but style is 'init'
   class HasRaisesSectionInit:
       """A class.
  -
  -    Raises:
  -        ValueError: If x is negative.
       """
   
       def __init__(self, x: int) -> None:
  '''
