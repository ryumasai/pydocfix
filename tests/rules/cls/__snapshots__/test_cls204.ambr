# name: TestCLS204.test_rule
  '''
  ━━━ Diagnostics ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  cls204.py:10:9: CLS204 [unsafe] __init__ docstring should not have a Raises section when class_docstring_style is 'class'.
     |
   9 | 
  10 |         Raises:
     |         ^^^^^^^
  11 |             ValueError: If x is negative.
     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  12 |         """
     |
  
  ━━━ Diff ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  --- cls204.py
  +++ cls204.py (fixed)
  @@ -6,9 +6,6 @@
   class InitHasRaisesClass:
       def __init__(self, x: int) -> None:
           """Initialize.
  -
  -        Raises:
  -            ValueError: If x is negative.
           """
           if x < 0:
               raise ValueError("x must be non-negative")
  '''
