  cls201.py:9:9: CLS201 [safe] __init__ docstring should not have a Returns section.
     |
   8 | 
   9 |         Returns:
     |         ^^^^^^^^
  10 |             None: Nothing.
     | ^^^^^^^^^^^^^^^^^^^^^^^^^^
  11 |         """
     |
  
  ━━━ Diff ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  --- cls201.py
  +++ cls201.py (fixed)
  @@ -5,9 +5,6 @@
   class InitHasReturnsSection:
       def __init__(self, x: int) -> None:
           """Initialize.
  -
  -        Returns:
  -            None: Nothing.
           """
           self.x = x
  '''
